   "source": [
    "def compute_metrics(states, x0):\n",
    "    \"\"\"\n",
    "    Returns five arrays, one value per timestep:\n",
    "      avg_displacement   – mean |x_i(t) - x_i(0)|\n",
    "      avg_dist_from_com  – mean |x_i(t) - COM(t)|   (COM ≈ 0 since fall=False)\n",
    "      width              – 2·sqrt(Var_x + Var_y)     horizontal extent (2-sigma diameter)\n",
    "      height             – z_max - z_min              vertical extent\n",
    "      aspect_ratio       – width / height\n",
    "    \"\"\"\n",
    "    n_steps = len(states)\n",
    "    avg_displacement  = np.empty(n_steps)\n",
    "    avg_dist_from_com = np.empty(n_steps)\n",
    "    width             = np.empty(n_steps)\n",
    "    height            = np.empty(n_steps)\n",
    "\n",
    "    for t, x in enumerate(states):\n",
    "        # 1. Displacement from initial configuration\n",
    "        avg_displacement[t] = np.linalg.norm(x - x0, axis=1).mean()\n",
    "\n",
    "        # 2. Distance from centre of mass\n",
    "        com = x.mean(axis=0)\n",
    "        avg_dist_from_com[t] = np.linalg.norm(x - com, axis=1).mean()\n",
    "\n",
    "        # 3. Width (horizontal) and height (vertical)\n",
    "        width[t]  = 2 * np.sqrt(x[:, 0].var() + x[:, 1].var())\n",
    "        height[t] = x[:, 2].max() - x[:, 2].min()\n",
    "\n",
    "    aspect_ratio = width / np.where(height > 0, height, np.nan)\n",
    "    return avg_displacement, avg_dist_from_com, width, height, aspect_ratio\n",
    "\n",
    "\n",
    "timesteps = np.arange(1, STEPS + 1)\n",
    "metrics = {}\n",
    "for n in PARTICLE_COUNTS:\n",
    "    metrics[n] = compute_metrics(all_states[n], initial_positions[n])\n",
    "\n",
    "print(\"Metrics computed for N =\", list(metrics.keys()))"
   ]
  },
