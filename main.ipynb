    "    (\"avg_dist_from_com\", r\"Average distance from CoM, $\\langle|\\mathbf{x} - \\mathbf{x}_{CoM}|\\rangle$\"),\n",
    "    (\"width\",             r\"Cloud width (2$\\sigma$ horizontal diameter)\"),\n",
    "    (\"height\",            r\"Cloud height ($z_{max} - z_{min}$)\"),\n",
    "    (\"aspect_ratio\",      r\"Aspect ratio (width / height)\"),\n",
    "]\n",
    "\n",
    "for ax, (_, ylabel) in zip(axes[:5], metric_labels):\n",
    "    ax.set_xlabel(\"Time step\")\n",
    "    ax.set_ylabel(ylabel)\n",
